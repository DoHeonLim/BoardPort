generator client {
  provider = "prisma-client"
  // 프로젝트 루트 기준: ./generated/prisma
  // (schema.prisma가 prisma/ 안에 있으니까 ../generated/prisma)
  output   = "../generated/prisma"
}

// URL은 prisma.config.ts + .env에서 관리
datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// User Domain (사용자 및 인증)
// -----------------------------------------------------------------------------

enum Role {
  USER
  ADMIN
}

enum RegionRange {
  DONG // 좁게 (동/읍/면)
  GU // 보통 (구/군) - 기본값
  CITY // 넓게 (시/도)
  ALL // 전국
}

/// 사용자 정보 모델
model User {
  id               Int       @id @default(autoincrement())
  username         String    @unique // 유저 닉네임 (표시용 이름)
  email            String?   @unique // 이메일 (로그인 ID)
  emailVerified    Boolean   @default(false) // 이메일 인증 여부
  password         String? // 비밀번호 (해시값)
  phone            String?   @unique // 휴대폰 번호 (SMS 인증용)
  kakao_id         String?   @unique // KAKAO 소셜 로그인 ID
  github_id        String?   @unique // GitHub 소셜 로그인 ID
  avatar           String? // 프로필 이미지 URL
  created_at       DateTime  @default(now()) // 가입일
  updated_at       DateTime  @updatedAt // 정보 수정일
  last_badge_check DateTime? // 뱃지 자동 부여 크론잡(Rolling Batch) 체크 시점
  role             Role      @default(USER) // 유저 역할
  bannedAt         DateTime? // 관리자에 의한 이용 정지 (Null이면 정상, 값이 있으면 정지된 시간)
  bannedUntil      DateTime? // 정지 만료 시점

  latitude     Float?
  longitude    Float?
  locationName String? // 예: "집 근처", "강남역" 등 유저가 지정한 별칭 또는 주소
  region1      String? // 시/도 (예: 부산광역시)
  region2      String? // 구/군 (예: 금정구) - *주 필터 기준*
  region3      String? // 동/읍/면 (예: 부곡동)
  regionRange  RegionRange @default(GU) // 유저가 설정한 동네 보기 범위 (기본값: GU)

  // --- Relations ---
  tokens               SMSToken[] // SMS 인증 토큰 목록
  products             Product[]         @relation("Seller") // 판매 등록한 상품들
  product_chat_rooms   ProductChatRoom[] // 참여 중인 상품 채팅방
  product_messages     ProductMessage[] // 상품 채팅 메시지
  product_likes        ProductLike[] // 찜한 상품 목록
  purchased_products   Product[]         @relation("PurchaseUser") // 구매한 상품 목록
  reservation_products Product[]         @relation("ReservationUser") // 예약 중인 상품 목록

  posts           Post[] // 작성한 커뮤니티 게시글
  post_likes      PostLike[] // 좋아요한 게시글
  comments        Comment[] // 작성한 댓글
  stream_messages StreamMessage[] // 라이브 채팅 메시지
  reviews         Review[] // 작성한 거래 후기
  badges          Badge[] // 획득한 뱃지 목록

  notifications            Notification[] // 수신한 알림
  push_subscriptions       PushSubscription[] // PWA 푸시 구독 정보
  notification_preferences NotificationPreferences? // 알림 수신 설정
  search_histories         SearchHistory[] // 검색 기록
  email_tokens             EmailToken[] // 이메일 인증 토큰

  followers Follow[] @relation("Followers") // 나를 팔로우하는 사람들
  following Follow[] @relation("Following") // 내가 팔로우하는 사람들

  recording_likes    RecordingLike[] // 녹화본 좋아요
  recording_comments RecordingComment[] // 녹화본 댓글
  live_inputs        LiveInput? // 스트리밍 송출 정보 (1인 1채널)
  view_throttles     ViewThrottle[] // 조회수 어뷰징 방지 기록
  blocked_users      Block[]            @relation("Blocker") // 내가 차단한 사람들
  blocked_by         Block[]            @relation("Blocked") // 나를 차단한 사람들
  reports            Report[]           @relation("ReportReporter") // 제출한 신고 내역
  reports_received   Report[]           @relation("ReportTargetUser") // 접수된 피신고 내역
  admin_logs         AuditLog[]         @relation("AdminActions") // 내가 수행한 관리 활동 로그(관리자용)
  keyword_alerts     KeywordAlert[]

  @@index([username]) // 유저 검색 최적화
}

// -----------------------------------------------------------------------------
// Auth & Verification (인증 토큰)
// -----------------------------------------------------------------------------

/// SMS 인증 번호 저장소
model SMSToken {
  id         Int      @id @default(autoincrement())
  token      String   @unique // 6자리 인증 번호
  phone      String?  @unique // 대상 전화번호
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int
}

/// 이메일 인증 토큰 저장소
model EmailToken {
  id         String   @id @default(cuid())
  token      String   @unique // 6자리 인증 번호
  email      String // 대상 이메일
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  expires_at DateTime // 토큰 만료 시간

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  @@index([userId])
}

// -----------------------------------------------------------------------------
// Social & Profile (뱃지, 팔로우)
// -----------------------------------------------------------------------------

/// 업적/뱃지 정보
model Badge {
  id          Int      @id @default(autoincrement())
  name        String   @unique // 뱃지 내부 식별자 (예: EARLY_SAILOR)
  icon        String // 뱃지 아이콘 URL
  description String // 뱃지 설명
  created_at  DateTime @default(now())

  users User[] // 이 뱃지를 획득한 유저들
}

/// 유저 간 팔로우 관계
model Follow {
  id         Int      @id @default(autoincrement())
  created_at DateTime @default(now())

  follower   User @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  followerId Int // 팔로우를 하는 사람 (Viewer)

  following   User @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)
  followingId Int // 팔로우를 받는 사람 (Target)

  @@unique([followerId, followingId]) // 중복 팔로우 방지
  // [Optimization] 팔로워/팔로잉 목록 조회 + 커서 페이지네이션 최적화
  @@index([followerId, id])
  @@index([followingId, id])
}

// -----------------------------------------------------------------------------
// Commerce Domain (중고 거래)
// -----------------------------------------------------------------------------

/// 중고 거래 상품 모델
model Product {
  id          Int            @id @default(autoincrement())
  title       String // 상품명
  price       Float // 가격
  description String // 상세 설명
  images      ProductImage[] // 상품 이미지들

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // 끌어올리기 (Bump) 관련 필드
  refreshed_at   DateTime  @default(now()) // 정렬 기준 시간 (생성 시엔 created_at과 동일)
  last_bumped_at DateTime? // 마지막으로 끌어올린 시간 (쿨다운 24시간 체크용)
  bump_count     Int       @default(0) // 끌어올리기 누적 횟수

  user   User @relation("Seller", fields: [userId], references: [id], onDelete: Cascade)
  userId Int // 판매자 ID

  chat_rooms ProductChatRoom[] // 이 상품에 대한 채팅방들

  // --- Transaction State (거래 상태) ---
  // 판매중: reservation_userId == null && purchase_userId == null
  // 예약중: reservation_userId != null
  // 판매완료: purchase_userId != null

  reservation_at     DateTime? // 예약 시점
  reservation_user   User?     @relation("ReservationUser", fields: [reservation_userId], references: [id], onDelete: SetNull)
  reservation_userId Int? // 예약자 ID

  purchase_user   User?     @relation("PurchaseUser", fields: [purchase_userId], references: [id], onDelete: SetNull)
  purchase_userId Int? // 구매자 ID
  purchased_at    DateTime? // 판매 완료 시점

  reviews       Review[] // 거래 후기
  product_likes ProductLike[] // 찜하기

  // --- Meta Info ---
  game_type    String // 게임 종류 (보드게임, TRPG, 카드게임)
  min_players  Int // 최소 인원
  max_players  Int // 최대 인원
  play_time    String // 플레이 시간
  condition    String // 상품 상태 (새상품, 사용감 있음 등)
  completeness String // 구성품 상태 (전체 보유, 일부 분실 등)
  has_manual   Boolean // 설명서 유무
  views        Int     @default(0) // 조회수

  category    Category    @relation(fields: [categoryId], references: [id])
  categoryId  Int
  search_tags SearchTag[] // 검색용 태그

  // --- Location Info (직거래 장소) --- 
  latitude     Float? // 위도
  longitude    Float? // 경도
  locationName String? // 위치 명
  region1      String? // 시/도
  region2      String? // 구/군
  region3      String? // 동/읍/면

  // 목록 정렬 인덱스: created_at -> refreshed_at (최신순 노출 기준 변경)
  @@index([refreshed_at(sort: Desc)]) // 메인 목록 최신순
  @@index([price]) // 가격 범위 검색
  @@index([game_type]) // 게임 타입 필터
  @@index([condition]) // 상태 필터
  // 복합 인덱스 (refreshed_at 기준)
  @@index([userId, refreshed_at(sort: Desc)]) // "내 판매 상품" 최신순
  @@index([categoryId, refreshed_at(sort: Desc)]) // "카테고리별" 최신순
  // (유지) 통계용 created_at 인덱스
  @@index([created_at(sort: Desc)])
  // 위치 
  @@index([latitude, longitude])
  @@index([region1, region2])
}

/// 상품 카테고리 (계층 구조 지원)
model Category {
  id          Int     @id @default(autoincrement())
  eng_name    String // 영문명 (코드용)
  kor_name    String // 한글명 (표시용)
  icon        String? // 아이콘 이모지
  description String? // 카테고리 설명

  products Product[]

  // 계층 구조 (대분류 > 소분류)
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  parentId Int?
  children Category[] @relation("CategoryHierarchy")

  @@index([parentId])
}

/// 상품 이미지
model ProductImage {
  id         Int      @id @default(autoincrement())
  url        String // 이미지 URL (Cloudflare)
  order      Int      @default(0) // 표시 순서 (0번이 대표 이미지)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int

  @@index([productId])
}

/// 상품 찜하기 (Like)
model ProductLike {
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  userId    Int
  productId Int

  @@id(name: "id", [userId, productId]) // 복합 키
}

/// 거래 후기 (Review)
model Review {
  id         Int      @id @default(autoincrement())
  payload    String // 후기 내용
  rate       Int // 별점 (1~5)
  created_at DateTime @default(now())

  user   User @relation(fields: [userId], references: [id]) // 작성자
  userId Int

  product   Product @relation(fields: [productId], references: [id]) // 대상 상품
  productId Int

  @@unique([userId, productId]) // 한 상품당 1개의 리뷰만 작성 가능
  // [Optimization] 리뷰 목록 조회 최적화
  @@index([productId, created_at]) // 상품 상세 > 리뷰 목록 (최신순)
  @@index([userId, created_at]) // 프로필 > 받은 후기 (최신순)
  @@index([rate]) // 별점 통계용
}

// -----------------------------------------------------------------------------
// Community Domain (항해일지 게시판)
// -----------------------------------------------------------------------------

/// 게시글 모델
model Post {
  id          Int      @id @default(autoincrement())
  title       String // 제목
  description String? // 본문 내용
  category    String // 게시판 카테고리 (자유, 공략, 후기 등)
  views       Int      @default(0) // 조회수
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // --- Location Info (모임 장소, 카페 위치 등) ---
  latitude     Float? // 위도
  longitude    Float? // 경도
  locationName String? // 위치 명
  region1      String? // 시/도
  region2      String? // 구/군
  region3      String? // 동/읍/면

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  comments   Comment[] // 댓글
  post_likes PostLike[] // 좋아요
  images     PostImage[] // 첨부 이미지
  tags       PostTag[] // 태그

  // [Optimization] 게시글 목록 조회
  @@index([category, created_at]) // 카테고리별 최신순
  @@index([userId, created_at]) // 유저별 작성글
  @@index([created_at]) // 전체 최신순
  @@index([title]) // 제목 검색
  @@index([latitude, longitude]) // "내 주변 게시글" 검색용
  @@index([region1, region2]) // "우리 동네 이야기" 필터용
}

/// 게시글 이미지
model PostImage {
  id         Int      @id @default(autoincrement())
  url        String
  order      Int      @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId Int

  @@index([postId])
}

/// 게시글 좋아요
model PostLike {
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId Int
  postId Int

  @@id(name: "id", [userId, postId])
}

/// 게시글 태그 (Many-to-Many via implicit relation)
model PostTag {
  id         Int      @id @default(autoincrement())
  name       String   @unique // 태그명 (중복 불가)
  count      Int      @default(0) // 사용 횟수 (인기 태그용)
  posts      Post[]
  created_at DateTime @default(now())

  @@index([name])
  @@index([count])
}

/// 게시글 댓글
model Comment {
  id         Int      @id @default(autoincrement())
  payload    String // 댓글 내용
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId Int
  postId Int

  // [Optimization] 댓글 목록 조회
  @@index([postId, created_at])
  @@index([userId])
}

// -----------------------------------------------------------------------------
// Chat Domain (1:1 상품 문의)
// -----------------------------------------------------------------------------

// 상품 채팅방
model ProductChatRoom {
  id         String   @id @default(cuid()) // CUID 사용
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt // 마지막 메시지 시간으로 갱신됨

  users    User[] // 참여자 (N:M)
  messages ProductMessage[]

  product      Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId    Int
  appointments Appointment[]

  @@index([updated_at]) // 채팅방 목록 정렬 (최신 대화순)
  @@index([productId])
}

// 메시지 타입
enum MessageType {
  TEXT
  IMAGE
  APPOINTMENT
  SYSTEM
}

// 채팅 메시지
model ProductMessage {
  id      Int     @id @default(autoincrement())
  payload String? // 이미지만 보낼 수도 있으므로 선택 사항으로 변경
  image   String? // Cloudflare 이미지 URL 저장 필드

  // 메시지 타입 및 약속 연결
  type          MessageType  @default(TEXT)
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  appointmentId Int?

  isRead Boolean @default(false) // 읽음 여부

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  room              ProductChatRoom? @relation(fields: [productChatRoomId], references: [id], onDelete: Cascade)
  productChatRoomId String?

  user   User @relation(fields: [userId], references: [id])
  userId Int

  // [Optimization] 메시지 내역 조회 & 안 읽은 메시지 카운트
  @@index([productChatRoomId, created_at])
  @@index([productChatRoomId, isRead, userId]) // 안 읽은 개수 집계용
}

// 약속 상태
enum AppointmentStatus {
  PENDING // 제안됨 (수락 대기)
  ACCEPTED // 수락됨 (거래 확정 -> 예약중 전환)
  REJECTED // 거절됨
  CANCELED // 취소됨
}

// 채팅 내 약속
model Appointment {
  id Int @id @default(autoincrement())

  // 약속 정보
  meetDate  DateTime // 약속 시간
  location  String // 장소명 (예: 강남역 11번 출구)
  latitude  Float
  longitude Float

  status AppointmentStatus @default(PENDING)

  // 채팅방과의 관계
  chatRoom   ProductChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  chatRoomId String

  proposerId Int // 제안한 사람 ID
  receiverId Int // 수신자 ID (수락해야 할 사람)

  // 이 약속을 담고 있는 메시지 (보통 1개)
  messages ProductMessage[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([chatRoomId])
  @@index([proposerId])
  @@index([receiverId])
}

// -----------------------------------------------------------------------------
// Notification Domain (알림 시스템)
// -----------------------------------------------------------------------------

/// 인앱 알림
model Notification {
  id     Int  @id @default(autoincrement())
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int // 수신자

  title String
  body  String
  image String?
  type  String // CHAT, TRADE, REVIEW, BADGE, SYSTEM, STREAM
  link  String? // 클릭 시 이동 경로

  isRead     Boolean  @default(false)
  created_at DateTime @default(now())

  isPushSent Boolean   @default(false) // 푸시 발송 성공 여부
  sentAt     DateTime? // 발송 시간

  @@index([userId, created_at]) // 내 알림함
  @@index([userId, isRead]) // 안 읽은 알림 필터
}

/// Web Push 구독 정보 (PWA)
model PushSubscription {
  id     Int  @id @default(autoincrement())
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  endpoint  String // 브라우저 엔드포인트
  p256dh    String // 암호화 키
  auth      String // 인증 키
  userAgent String?

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  last_used  DateTime? // 마지막 발송 성공 시간
  isActive   Boolean   @default(true) // 구독 활성 상태

  @@unique([endpoint, userId], name: "endpoint_userId")
  @@index([userId, isActive])
}

/// 사용자 알림 설정
model NotificationPreferences {
  id     Int  @id @default(autoincrement())
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int  @unique

  // 알림 종류별 ON/OFF
  chat    Boolean @default(true)
  trade   Boolean @default(true)
  review  Boolean @default(true)
  badge   Boolean @default(true)
  system  Boolean @default(true)
  stream  Boolean @default(true)
  keyword Boolean @default(true)

  pushEnabled Boolean @default(true) // 전체 푸시 ON/OFF

  // 방해 금지 시간
  quietHoursStart String? // "22:00"
  quietHoursEnd   String? // "08:00"
}

// -----------------------------------------------------------------------------
// Search Domain
// -----------------------------------------------------------------------------

/// 유저 최근 검색어
model SearchHistory {
  id         Int      @id @default(autoincrement())
  keyword    String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // 필터 조건 저장 (선택)
  category  String?
  minPrice  Int?
  maxPrice  Int?
  game_type String?
  condition String?

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  @@index([userId, updated_at]) // 최근 검색어 정렬
  @@index([keyword])
}

/// 검색 태그 (상품 태그)
model SearchTag {
  id         Int       @id @default(autoincrement())
  name       String    @unique
  count      Int       @default(0) // 사용 횟수
  products   Product[]
  created_at DateTime  @default(now())

  @@index([name])
  @@index([count])
}

/// 인기 검색어 (집계용)
model PopularSearch {
  id         Int      @id @default(autoincrement())
  keyword    String   @unique
  count      Int      @default(0) // 검색 횟수
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([count(sort: Desc)]) // 인기순 정렬
}

model KeywordAlert {
  id          Int         @id @default(autoincrement())
  userId      Int
  keyword     String // 감지할 키워드 (소문자 저장 권장)
  regionRange RegionRange @default(GU) // 키워드 별 감지 범위
  created_at  DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, keyword]) // 한 유저가 같은 키워드 중복 등록 방지
  @@index([keyword]) // 상품 등록 시 매칭 검색 성능 최적화
}

// -----------------------------------------------------------------------------
// Streaming Domain (라이브 & 녹화)
// -----------------------------------------------------------------------------

/// 송출 채널 (1인 1채널) - Cloudflare Live Input과 1:1 매핑
model LiveInput {
  id     Int  @id @default(autoincrement())
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  provider_uid String  @unique // Cloudflare Live Input UID
  stream_key   String // OBS 송출 키 (RTMPS)
  name         String?

  // CF 설정 동기화
  deleteAfterDays     Int?
  requireSignedURLs   Boolean @default(false)
  hideLiveViewerCount Boolean @default(false)

  status String? // 현재 연결 상태 캐시 (CONNECTED / DISCONNECTED)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  broadcasts Broadcast[] // 이 채널로 송출한 방송 이력

  @@unique([userId])
  @@index([userId])
}

enum StreamVisibility {
  PUBLIC
  FOLLOWERS
  PRIVATE
}

/// 방송 세션 (OBS 연결 ~ 종료까지의 1회 방송)
model Broadcast {
  id Int @id @default(autoincrement())

  liveInput   LiveInput @relation(fields: [liveInputId], references: [id], onDelete: Cascade)
  liveInputId Int

  title       String // 방송 제목
  description String? // 방송 설명
  thumbnail   String? // 썸네일 이미지

  visibility StreamVisibility // PUBLIC, FOLLOWERS, PRIVATE
  password   String? // PRIVATE일 경우 비밀번호 (해시)

  status     String // CONNECTED, ENDED, DISCONNECTED
  started_at DateTime? // 방송 시작 시간
  ended_at   DateTime? // 방송 종료 시간

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  category         StreamCategory? @relation(fields: [streamCategoryId], references: [id])
  streamCategoryId Int?
  tags             StreamTag[]     @relation("BroadcastTags")

  chatRoom  StreamChatRoom? // 방송 채팅방
  vodAssets VodAsset[] // 녹화본 (VOD)

  // [Optimization] 방송 목록 조회 인덱스
  @@index([liveInputId, id]) // 유저 채널 목록
  @@index([status, id]) // 라이브 중인 방송 목록
  @@index([started_at])
  @@index([streamCategoryId])
}

/// 녹화본 (VOD) - Cloudflare Video
model VodAsset {
  id          Int       @id @default(autoincrement())
  broadcast   Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  broadcastId Int // 원본 방송 ID

  provider_asset_id String    @unique // Cloudflare Video UID
  playback_hls      String?
  playback_dash     String?
  thumbnail_url     String?
  duration_sec      Int? // 영상 길이 (초)
  ready_at          DateTime? // 처리 완료 시간

  views Int @default(0) // 조회수

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  recordingLikes    RecordingLike[] // 녹화본 좋아요
  recordingComments RecordingComment[] // 녹화본 댓글

  @@index([broadcastId])
  @@index([ready_at])
  @@index([views])
}

/// 방송 태그
model StreamTag {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  broadcasts Broadcast[] @relation("BroadcastTags")

  @@index([name])
}

/// 방송 카테고리
model StreamCategory {
  id          Int     @id @default(autoincrement())
  eng_name    String
  kor_name    String
  icon        String?
  description String?

  broadcasts Broadcast[]

  parent   StreamCategory?  @relation("StreamCategoryHierarchy", fields: [parentId], references: [id])
  parentId Int?
  children StreamCategory[] @relation("StreamCategoryHierarchy")

  @@index([parentId])
}

/// 방송 채팅방 (세션 1개당 1개)
model StreamChatRoom {
  id         Int      @id @default(autoincrement())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  broadcast   Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  broadcastId Int       @unique

  stream_messages StreamMessage[]
}

/// 방송 채팅 메시지
model StreamMessage {
  id         Int      @id @default(autoincrement())
  payload    String
  created_at DateTime @default(now())

  stream_chat_room StreamChatRoom @relation(fields: [streamChatRoomId], references: [id], onDelete: Cascade)
  streamChatRoomId Int

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  // [Optimization] 채팅 기록 조회 (시간순)
  @@index([streamChatRoomId, created_at])
  @@index([userId])
}

/// 녹화본 좋아요
model RecordingLike {
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vod  VodAsset @relation(fields: [vodId], references: [id], onDelete: Cascade)

  userId Int
  vodId  Int

  @@id([userId, vodId], name: "id")
}

/// 녹화본 댓글
model RecordingComment {
  id         Int      @id @default(autoincrement())
  payload    String
  created_at DateTime @default(now())

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vod  VodAsset @relation(fields: [vodId], references: [id], onDelete: Cascade)

  userId Int
  vodId  Int

  // [Optimization] 댓글 조회 (시간순)
  @@index([vodId, created_at])
}

// -----------------------------------------------------------------------------
// Utils & Analytics (조회수 제어)
// -----------------------------------------------------------------------------

enum ViewTargetType {
  POST
  PRODUCT
  VOD
}

/// 조회수 어뷰징 방지 (쓰로틀링)
model ViewThrottle {
  id           Int            @id @default(autoincrement())
  userId       Int
  targetType   ViewTargetType
  targetId     Int
  lastViewedAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId]) // 유저-타입-ID 조합 유니크
  @@index([targetType, targetId])
  @@index([userId])
}

// -----------------------------------------------------------------------------
// Safety & Moderation (안전 및 운영)
// -----------------------------------------------------------------------------

/// 차단 모델
model Block {
  id        Int  @id @default(autoincrement())
  blocker   User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockerId Int

  blocked   User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  blockedId Int

  created_at DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
}

/// 신고 사유 Enum
enum ReportReason {
  SPAM // 스팸/광고
  INAPPROPRIATE // 부적절한 콘텐츠
  ABUSIVE // 욕설/비하
  SCAM // 사기 의심
  OTHER // 기타
}

// 신고 모델
model Report {
  id Int @id @default(autoincrement())

  // 신고자 (Reporter)
  reporter   User @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reporterId Int

  // 신고 대상 (Target)
  targetUser             User? @relation("ReportTargetUser", fields: [targetUserId], references: [id])
  targetUserId           Int?
  targetProductId        Int? // 제품
  targetPostId           Int? // 게시글
  targetCommentId        Int? // 댓글(게시글, 녹화본)
  targetStreamId         Int? // Broadcast ID
  targetProductMessageId Int? // 1:1 거래 채팅 메시지
  targetStreamMessageId  Int? // 라이브 방송 채팅 메시지
  targetReviewId         Int? // 리뷰

  reason       ReportReason // 신고 사유 (Enum)
  description  String? // 상세 설명 (선택)
  adminComment String? // 관리자 처리 코멘트 (기각 사유, 조치 내용 등)

  status     String   @default("PENDING") // PENDING, RESOLVED, DISMISSED
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([reporterId])
  @@index([status])
  // 검색 성능을 위한 타겟별 인덱스 전체 추가
  @@index([targetUserId])
  @@index([targetProductId])
  @@index([targetPostId])
  @@index([targetCommentId])
  @@index([targetStreamId])
  @@index([targetProductMessageId])
  @@index([targetStreamMessageId])
  @@index([targetReviewId])
}

/// 관리자 활동 감사 로그
model AuditLog {
  id Int @id @default(autoincrement())

  // 수행한 관리자 정보
  admin   User @relation("AdminActions", fields: [adminId], references: [id], onDelete: Cascade)
  adminId Int

  // 액션 정보
  action String // "BAN_USER", "UNBAN_USER", "DELETE_PRODUCT", "RESOLVE_REPORT", "CHANGE_ROLE"

  // 대상 정보
  targetType String // "USER", "PRODUCT", "POST", "REPORT", etc.
  targetId   Int // 대상의 PK

  // 상세 내용
  reason String? // 처리 사유 (관리자 코멘트)

  created_at DateTime @default(now())

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([action])
}
